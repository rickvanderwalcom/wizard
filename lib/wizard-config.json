        {
          "id": "address",
          "label": "Straat + huisnummer",
          "type": "text",
          "required": true,
          "placeholder": "bijv. Kerkstraat 12"
        },
        {
          "id": "city",
          "label": "Plaats",
          "type": "text",
          "required": true,
          "placeholder": "bijv. Amsterdam"
        },
        {
          "id": "website",
          "label": "Website",
          "type": "url",
          "required": false,
          "placeholder": "www.jullierestarant.nl"
        }
      ]
    },

